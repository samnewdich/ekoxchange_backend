generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/mongodb"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_PRISMA_URL")
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  email String @unique

  provider String @default("local") // local, google, apple

  providerId String? @unique

  fullname String?

  firstname String?

  lastname String?

  username String @unique

  password String?

  phone String?

  country String?

  timeZone String?

  referralCode String?

  deviceID String?

  latitude Float?

  longitude Float?

  locationName String?

  deviceName String?

  otp String?

  otpCreatedTime Int?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  isEmailVerified Boolean?

  isPhoneVerified Boolean?
}
